{
  "name": "delivery-graph",
  "role": "primitive",
  "kind": "oneshot",
  "describe": "Refresh delivery context by deriving CI health and pull request flow reports.",
  "inputs": [],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "default",
    "maxTurns": 0,
    "maxThinkingTokens": null,
    "systemPromptAppend": null,
    "cacheable": true,
    "tools": [],
    "hooks": [],
    "skills": [
      "ci-health-graph",
      "pr-graph"
    ],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": [
    {
      "name": "gh",
      "install": {
        "required": true,
        "checkCommand": "gh --version"
      },
      "verify": "gh auth status",
      "usage": "Read GitHub Actions and pull request data for delivery reports.",
      "allowedUses": [
        "read workflow runs",
        "read pull requests"
      ]
    },
    {
      "name": "jq",
      "install": {
        "required": true,
        "checkCommand": "jq --version"
      },
      "verify": "jq --version",
      "usage": "Parse JSON data while refreshing delivery reports.",
      "allowedUses": [
        "parse local command output"
      ]
    }
  ],
  "scripts": {
    "preflight": [
      {
        "script": "buildSyntheticPlugin"
      },
      {
        "shell": "refresh-delivery-graphs.sh"
      },
      {
        "script": "skipAgent"
      }
    ],
    "postflight": []
  },
  "output": {
    "actionTypes": [
      "DELIVERY_GRAPH_REFRESHED",
      "DELIVERY_GRAPH_FAILED",
      "AGENT_NOT_RUN"
    ]
  }
}
